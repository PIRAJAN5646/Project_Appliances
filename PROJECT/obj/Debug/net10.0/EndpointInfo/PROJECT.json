            "format": "int32"
          },
          "applianceType": {
            "$ref": "#/components/schemas/ApplianceType"
          },
          "home_id": {
            "type": "integer",
            "format": "int32"
          },
          "home": {
            "$ref": "#/components/schemas/Home"
          },
          "model": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "device_identifier": {
            "type": "string",
            "nullable": true
          },
          "installed_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ApplianceType": {
        "required": [
