  "components": {
    "schemas": {
      "Alert": {
        "required": [
          "alert_type",
          "is_resolved",
          "message",
          "severity"
        ],
        "type": "object",
        "properties": {
          "alert_id": {
            "type": "integer",
            "format": "int32"
          },
          "appliance_id": {
            "type": "integer",
            "format": "int32"
          },
          "alert_type": {
            "minLength": 1,
            "type": "string"
          },
          "message": {
            "minLength": 1,
            "type": "string"
          },
          "is_resolved": {
            "type": "boolean"
          },
          "severity": {
            "type": "number",
            "format": "double"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "AlertsDTO": {
        "type": "object",
        "properties": {
          "appliance_id": {
            "type": "integer",
            "format": "int32"
          },
          "alert_type": {
            "type": "string",
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "is_resolved": {
            "type": "boolean"
          },
          "severity": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Appliance": {
        "type": "object",
        "properties": {
