          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "category": {
            "minLength": 1,
            "type": "string"
          },
          "avg_energy_rating": {
            "type": "number",
            "format": "double"
          },
          "avg_water_rating": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
